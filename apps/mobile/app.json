{
  "expo": {
    "name": "SpotlyClean",
    "slug": "spotlyclean",
    "version": "1.0.0",
    "scheme": "spotlyclean",
    "ios": {
      "bundleIdentifier": "com.spotlyclean.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.spotlyclean.app",
      "adaptiveIcon": {
        "backgroundColor": "#0ea5e9"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0ea5e9"
        }
      ]
    ]
  }
}
